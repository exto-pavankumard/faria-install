# Faria Environment Configuration
# ================================
#
# Copy this file to ~/.faria/.env or add these exports to your shell profile
# (~/.bashrc, ~/.zshrc, ~/.profile, or PowerShell $PROFILE)
#
# Note: If using the default ~/.faria/ installation path, these environment
# variables are OPTIONAL - Faria will auto-detect the paths.

# =============================================================================
# REQUIRED: Core Dependencies
# =============================================================================

# ONNX Runtime Library Path
# -------------------------
# The path to the ONNX Runtime shared library.
# This is required for running ML inference.
#
# Platform-specific values:
#   macOS:   ~/.faria/lib/onnxruntime/libonnxruntime.dylib
#   Linux:   ~/.faria/lib/onnxruntime/libonnxruntime.so
#   Windows: %USERPROFILE%\.faria\lib\onnxruntime\onnxruntime.dll
#
FARIA_ONNXRUNTIME_PATH="${HOME}/.faria/lib/onnxruntime/libonnxruntime.dylib"

# DETR Model Path
# ---------------
# Document layout detection model (detects tables, headers, text blocks, etc.)
# Model size: ~350 MB
#
FARIA_DETR_MODEL_PATH="${HOME}/.faria/models/detr_layout_detection.onnx"

# Nemotron Model Path
# -------------------
# Table structure detection model (detects cells, rows, columns within tables)
# Model size: ~200 MB
#
FARIA_NEMOTRON_MODEL_PATH="${HOME}/.faria/models/nemotron_table_structure.onnx"

# =============================================================================
# OPTIONAL: LLM for Cross-Page Table Merging
# =============================================================================
#
# These are only required if EnableAutoMerger = true in your configuration.
# The LLM provides intelligent cross-page table merging capabilities.
#

# llama.cpp CLI Path
# ------------------
# The llama-cli executable for running the LLM.
# Size: ~5 MB
#
FARIA_LLAMA_CLI_PATH="${HOME}/.faria/bin/llama-cli"

# SLM (Small Language Model) Path
# -------------------------------
# The Qwen 2.5 model for intelligent table merging decisions.
# Model size: ~530 MB
#
FARIA_SLM_MODEL_PATH="${HOME}/.faria/models/qwen2.5-0.5b-instruct-q8_0.gguf"

# =============================================================================
# OPTIONAL: Performance Tuning
# =============================================================================
#
# These settings can be used to tune performance for your system.
# Uncomment and modify as needed.
#

# Worker Count
# ------------
# Number of parallel workers for document processing.
# Default: Number of CPU cores
#
# FARIA_WORKER_COUNT=8

# GPU Layers (LLM)
# ----------------
# Number of model layers to offload to GPU for LLM inference.
# 0 = CPU only, 99 = all layers on GPU
# Default: 99 (use GPU if available)
#
# FARIA_GPU_LAYERS=99

# Context Size (LLM)
# ------------------
# Context window size for the LLM.
# Larger values allow processing more text but use more memory.
# Default: 4096
#
# FARIA_CONTEXT_SIZE=4096

# =============================================================================
# Usage Examples
# =============================================================================
#
# Bash/Zsh (add to ~/.bashrc or ~/.zshrc):
# ----------------------------------------
#   export FARIA_ONNXRUNTIME_PATH="$HOME/.faria/lib/onnxruntime/libonnxruntime.dylib"
#   export FARIA_DETR_MODEL_PATH="$HOME/.faria/models/detr_layout_detection.onnx"
#   export FARIA_NEMOTRON_MODEL_PATH="$HOME/.faria/models/nemotron_table_structure.onnx"
#
# PowerShell (add to $PROFILE):
# -----------------------------
#   $env:FARIA_ONNXRUNTIME_PATH = "$env:USERPROFILE\.faria\lib\onnxruntime\onnxruntime.dll"
#   $env:FARIA_DETR_MODEL_PATH = "$env:USERPROFILE\.faria\models\detr_layout_detection.onnx"
#   $env:FARIA_NEMOTRON_MODEL_PATH = "$env:USERPROFILE\.faria\models\nemotron_table_structure.onnx"
#
# Or set permanently in PowerShell:
#   [Environment]::SetEnvironmentVariable('FARIA_ONNXRUNTIME_PATH', "$env:USERPROFILE\.faria\lib\onnxruntime\onnxruntime.dll", 'User')
#
